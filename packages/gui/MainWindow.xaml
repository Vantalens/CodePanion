<Window x:Class="RemindAI.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        mc:Ignorable="d"
        Title="RemindAI" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- 会话状态颜色 -->
        <SolidColorBrush x:Key="RunningBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="WaitingBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="ExitedBrush" Color="#9E9E9E"/>
    </Window.Resources>

    <Grid>
        <!-- 系统托盘图标 -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        IconSource="icon.ico"
                        ToolTipText="RemindAI"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示主窗口" Click="ShowWindow_Click"/>
                    <Separator/>
                    <MenuItem Header="连接状态" x:Name="ConnectionStatusMenuItem" IsEnabled="False"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="RemindAI" FontSize="18" FontWeight="Bold" Margin="0,0,16,0"/>
                    <Ellipse x:Name="StatusIndicator" Width="12" Height="12" Fill="Gray" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusText" Text="未连接" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="刷新" Click="Refresh_Click" Width="80"/>
                    <Button Content="设置" Click="Settings_Click" Width="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 主内容区 -->
        <TabControl Grid.Row="1" Margin="0">
            <!-- 会话列表标签页 -->
            <TabItem Header="活动会话">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FAFAFA" Padding="12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <TextBlock>
                            <Run Text="当前活动会话："/>
                            <Run x:Name="SessionCountText" Text="0" FontWeight="Bold"/>
                        </TextBlock>
                    </Border>

                    <ListView Grid.Row="1" x:Name="SessionListView" Margin="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="命令" Width="200" DisplayMemberBinding="{Binding Command}"/>
                                <GridViewColumn Header="状态" Width="100">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="running">
                                                                    <Setter Property="Fill" Value="{StaticResource RunningBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="waiting">
                                                                    <Setter Property="Fill" Value="{StaticResource WaitingBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="exited">
                                                                    <Setter Property="Fill" Value="{StaticResource ExitedBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="开始时间" Width="150" DisplayMemberBinding="{Binding StartedAtText}"/>
                                <GridViewColumn Header="工作目录" Width="250" DisplayMemberBinding="{Binding Cwd}"/>
                                <GridViewColumn Header="操作" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="查看" Click="ViewSession_Click" Tag="{Binding Id}" Width="60" Padding="6,2"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </TabItem>

            <!-- 日志标签页 -->
            <TabItem Header="日志">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogTextBox"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 FontFamily="Consolas, Courier New"
                                 FontSize="12"
                                 Background="#1E1E1E"
                                 Foreground="#D4D4D4"
                                 BorderThickness="0"
                                 Padding="12"/>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="12">
                        <Button Content="清空日志" Click="ClearLog_Click" HorizontalAlignment="Right" Width="100"/>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="StatusBarText" Text="就绪" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" x:Name="VersionText" Text="v0.1.0" VerticalAlignment="Center" Foreground="Gray"/>
            </Grid>
        </Border>
    </Grid>
</Window>
