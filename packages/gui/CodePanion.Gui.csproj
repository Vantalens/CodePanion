<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <AssemblyName>CodePanion.Gui</AssemblyName>
    <RootNamespace>CodePanion.Gui</RootNamespace>
    <ApplicationIcon>Assets\app-icon.ico</ApplicationIcon>
    <NuGetAudit>true</NuGetAudit>
    <NuGetAuditMode>direct</NuGetAuditMode>
    <NoWarn>$(NoWarn);NU1900</NoWarn>
  </PropertyGroup>

  <!-- A-2: keep GUI version in lockstep with root package.json so daemon and GUI never drift. -->
  <PropertyGroup>
    <_RootPackageJson>$(MSBuildThisFileDirectory)..\..\package.json</_RootPackageJson>
  </PropertyGroup>
  <PropertyGroup Condition="Exists('$(_RootPackageJson)')">
    <_RootPackageJsonText>$([System.IO.File]::ReadAllText('$(_RootPackageJson)'))</_RootPackageJsonText>
    <_RootPackageJsonVersion>$([System.Text.RegularExpressions.Regex]::Match($(_RootPackageJsonText), '&quot;version&quot;\s*:\s*&quot;([^&quot;]+)&quot;').Groups[1].Value)</_RootPackageJsonVersion>
  </PropertyGroup>
  <PropertyGroup Condition="'$(_RootPackageJsonVersion)' != ''">
    <Version>$(_RootPackageJsonVersion)</Version>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Version)' == ''">
    <Version>0.0.0</Version>
  </PropertyGroup>

  <Target Name="BuildDaemonBundle" BeforeTargets="BeforeBuild">
    <Message Text="Building daemon bundle for GUI output..." Importance="High" />
    <Exec WorkingDirectory="$(MSBuildThisFileDirectory)..\.." Command="npm run build:daemon-bundle" />
  </Target>

  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.2592.51" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <PackageReference Include="Websocket.Client" Version="5.1.2" />
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="1.1.0" />
  </ItemGroup>

  <ItemGroup>
    <None Update="wwwroot\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Assets\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="..\daemon\bundle\daemon.cjs" Link="daemon\daemon.cjs" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
