<Window x:Class="CodePanion.Gui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置 - CodePanion"
        Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0">
            <!-- 通用设置 -->
            <TabItem Header="通用">
                <StackPanel Margin="16">
                    <GroupBox Header="启动设置" Margin="0,0,0,16">
                        <StackPanel Margin="12">
                            <CheckBox x:Name="AutoStartCheckBox"
                                      Content="开机自动启动"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="MinimizeToTrayCheckBox"
                                      Content="启动时最小化到托盘"
                                      IsChecked="True"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="通知设置" Margin="0,0,0,16">
                        <StackPanel Margin="12">
                            <CheckBox x:Name="NotificationEnabledCheckBox"
                                      Content="启用桌面通知"
                                      IsChecked="True"
                                      Margin="0,0,0,8"/>
                            <CheckBox x:Name="NotificationSoundCheckBox"
                                      Content="播放通知声音"
                                      IsChecked="True"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="外观">
                        <StackPanel Margin="12">
                            <TextBlock Text="主题：" Margin="0,0,0,8"/>
                            <ComboBox x:Name="ThemeComboBox" SelectedIndex="0">
                                <ComboBoxItem Content="跟随系统"/>
                                <ComboBoxItem Content="浅色"/>
                                <ComboBoxItem Content="深色"/>
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- 连接设置 -->
            <TabItem Header="连接">
                <StackPanel Margin="16">
                    <GroupBox Header="Daemon 连接">
                        <StackPanel Margin="12">
                            <TextBlock Text="端口：" Margin="0,0,0,8"/>
                            <TextBox x:Name="PortTextBox" Text="7777" Margin="0,0,0,16"/>

                            <TextBlock Text="Token：" Margin="0,0,0,8"/>
                            <TextBox x:Name="TokenTextBox" IsReadOnly="True" Margin="0,0,0,8"/>

                            <TextBlock Text="配置文件位置：" Margin="0,16,0,8"/>
                            <TextBox x:Name="ConfigPathTextBox" IsReadOnly="True"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </TabItem>

            <!-- 关于 -->
            <TabItem Header="关于">
                <StackPanel Margin="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="CodePanion"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="版本 0.1.0"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Foreground="Gray"
                               Margin="0,0,0,24"/>

                    <TextBlock TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,16">
                        <Run Text="智能开发助手工具"/>
                        <LineBreak/>
                        <Run Text="用于 VSCode、Codex 等 AI 编程工具"/>
                    </TextBlock>

                    <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0">
                        <Hyperlink NavigateUri="https://github.com/yourusername/codepanion"
                                   RequestNavigate="Hyperlink_RequestNavigate">
                            GitHub 项目主页
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="保存"
                    Click="Save_Click"
                    Width="80"
                    IsDefault="True"/>
            <Button Content="取消"
                    Click="Cancel_Click"
                    Width="80"/>
        </StackPanel>
    </Grid>
</Window>
