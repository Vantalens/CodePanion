{
  "name": "codepanion-vscode-extension",
  "displayName": "CodePanion Monitor",
  "description": "Reports VS Code window, task lifecycle, terminal, and debug session activity to CodePanion daemon.",
  "version": "0.1.0",
  "publisher": "codepanion",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "CodePanion",
      "properties": {
        "codepanion.port": {
          "type": "number",
          "default": 7777,
          "description": "CodePanion daemon port."
        },
        "codepanion.token": {
          "type": "string",
          "default": "",
          "description": "CodePanion daemon token. Leave empty to read ~/.codepanion/config.json."
        },
        "codepanion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable VS Code window monitoring."
        }
      }
    }
  }
}
