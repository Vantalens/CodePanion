{
  "manifest_version": 3,
  "name": "RemindAI Browser Monitor",
  "version": "0.1.0",
  "description": "Reports allowlisted AI web chat completion and prompt states to RemindAI.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
